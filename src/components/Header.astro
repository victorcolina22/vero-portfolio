---
import Container from './Container.astro';
import Logo from './Logo.astro';
import StarEightTip from './icons/StarEightTip.astro';
import WhatsAppLogo from './icons/WhatsAppLogo.astro';
import WorksCard from './WorksCard.astro';
---

<Container>
  <header class="flex items-center justify-between px-[75px] pt-[33px]">
    <label class="flex items-center cursor-pointer group relative" for="toggle">
      <div class="-mt-3 -mr-7 z-0 group-hover:rotate-45 transition-transform">
        <StarEightTip />
      </div>
      <p
        class="uppercase font-oswald font-semibold text-4xl z-10 group-hover:underline"
      >
        works
      </p>
      <input type="checkbox" class="hidden" id="toggle" />
    </label>
    <div class="cursor-pointer"><Logo /></div>
    <div class="cursor-pointer hover:scale-125 transition-transform">
      <WhatsAppLogo />
    </div>

    <WorksCard
      class="workscard z-20 absolute top-[90px] left-[300px] transition-all"
    />
  </header>
</Container>

<style is:inline>
  .workscard {
    opacity: 0;
  }

  header:has(input:checked) {
    & .workscard {
      opacity: 1;
    }
  }
</style>
