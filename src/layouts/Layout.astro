---
import '../styles/global.css';

import Header from '@/components/Header.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Vero Mendoza | Portafolio</title>
    <meta
      name="description"
      content="Portafolio de Vero Mendoza — Diseñadora de experiencias digitales con enfoque humano."
    />
  </head>
  <body class="bg-white font-poppins text-dark-blue">
    <Header />
    <slot />
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
</style>
